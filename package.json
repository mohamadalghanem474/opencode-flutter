{
  "name": "opencode-flutter",
  "version": "0.1.0",
  "description": "Production-grade OpenCode plugin for Flutter — multi-model orchestration, agent harness, LSP tools, and discipline hooks",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "opencode-flutter": "bin/opencode-flutter.js"
  },
  "files": [
    "dist",
    "bin",
    "postinstall.mjs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": "./dist/opencode-flutter.schema.json"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly && bun run build:cli",
    "build:cli": "bun build src/cli/index.ts --outdir dist/cli --target node --format esm --packages external",
    "build:schema": "bun run script/build-schema.ts",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "prepublishOnly": "bun run clean && bun run build",
    "postinstall": "node postinstall.mjs",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "flutter",
    "dart",
    "agents",
    "tools",
    "orchestration",
    "lsp",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohamadalghanem474/opencode-flutter.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.2",
    "@opencode-ai/sdk": "^1.4.0",
    "commander": "^14.0.2",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "vscode-jsonrpc": "^8.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^5.7.3"
  }
}
